# BNotes _headers — Cloudflare Pages Cache Control
# Updated: fix cache priority order — specific rules LAST to override globals

# 靜態圖片/資源 - 長快取（1年）
/images/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 一般 JS / CSS - 長快取（1年，immutable）
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# HTML - 短快取（1小時 + 重驗證）
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/
  Cache-Control: public, max-age=3600, must-revalidate

# API/管理後台 - 不快取
/api/*
  Cache-Control: no-store, no-cache
  X-Content-Type-Options: nosniff

/admin/*
  Cache-Control: no-store, no-cache

# ⚠️ admin-app.js 必須在 /*.js 之後，以確保此規則優先生效（Cloudflare Pages last-match-wins）
/admin-app.js
  Cache-Control: no-store, no-cache, must-revalidate

/admin-app-v2.js
  Cache-Control: no-store, no-cache, must-revalidate

/admin-app-v3.js
  Cache-Control: no-store, no-cache, must-revalidate

# 安全標頭
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
