# ══════════════════════════════════════════════════════
# BNotes 環境變數說明（複製為 .env.local，填入真實值）
# .env.local 已在 .gitignore，不會上傳到 GitHub
# ══════════════════════════════════════════════════════

# ── Cloudflare Pages 部署 ──────────────────────────────
# 取得：https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=ee8cf81b23462d6f383669a02e05b999

# ── Google Imagen 4 圖片生成 ───────────────────────────
# 取得：https://aistudio.google.com/app/apikey
# 本地用法：GOOGLE_AI_KEY=xxx node 05_Scripts/generate-hero-image.js <slug>
GOOGLE_AI_KEY=your_google_ai_key_here

# ══════════════════════════════════════════════════════
# GitHub Actions Secrets（在 GitHub Repo Settings 設定，不寫在此）
# https://github.com/stanleytsoubiz/BNotes/settings/secrets/actions
# ══════════════════════════════════════════════════════
# CLOUDFLARE_API_TOKEN   ← 同上
# CLOUDFLARE_ACCOUNT_ID  ← ee8cf81b23462d6f383669a02e05b999
# GSC_SERVICE_ACCOUNT_JSON ← 05_Scripts/analytics/service_account.json 全文
